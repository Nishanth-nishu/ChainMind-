# =============================================================================
# ChainMind — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Gemini API Keys (comma-separated for round-robin) ---
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (optional) ---
OPENAI_API_KEYS=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (optional, local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- LLM Router ---
LLM_PRIMARY_PROVIDER=gemini
LLM_FALLBACK_CHAIN=gemini,openai,ollama
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RECOVERY_SECONDS=60

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RATE_LIMIT_PER_MINUTE=60
API_KEY=changeme-in-production

# --- gRPC Server ---
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_MAX_WORKERS=10

# --- Retrieval / RAG ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMADB_PERSIST_DIR=./data/chromadb
RETRIEVAL_TOP_K=10
RERANKER_TOP_K=5
RETRIEVAL_MODE=hybrid

# --- Memory ---
MEMORY_SHORT_TERM_MAX_TOKENS=4000
MEMORY_LONG_TERM_DB_PATH=./data/memory.db

# --- Guardrails ---
GUARDRAILS_ENABLED=true
MAX_INPUT_LENGTH=10000
MAX_OUTPUT_TOKENS=4096
MAX_AGENT_STEPS=15

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
TRACING_ENABLED=true
METRICS_ENABLED=true

# --- Deployment ---
ENVIRONMENT=development
DEBUG=false
